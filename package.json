{
  "name": "parking-app",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "build:preview": "eas build --platform android --profile preview",
    "build:prod": "eas build --platform android --profile production",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "cd functions && npm run build && cd .. && firebase deploy --only functions",
    "deploy:all": "npm run deploy:rules && npm run deploy:functions",
    "emulator": "firebase emulators:start"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "^55.0.9",
    "expo-notifications": "~0.28.0",
    "expo-status-bar": "~1.12.1",
    "firebase": "^10.12.0",
    "react": "18.2.0",
    "react-native": "^0.84.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "^3.32.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "eas-cli": "^18.4.0",
    "firebase-tools": "^15.12.0",
    "typescript": "^5.3.0"
  },
  "private": true
}
