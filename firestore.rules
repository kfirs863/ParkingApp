rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasRegisteredSpot() {
      return isAuth() &&
        'ownedSpot' in userDoc(request.auth.uid) &&
        userDoc(request.auth.uid).ownedSpot != null;
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    // ── Update rule helpers ──────────────────────────────

    // Requester cancels their own open request
    function canRequesterUpdate() {
      return existingData().requesterId == request.auth.uid
        && existingData().status == 'open'
        && incomingData().status == 'cancelled'
        && incomingData().requesterId == existingData().requesterId;
    }

    // Spot owner approves an open request (regular → approved, guest → confirmed)
    function canOwnerApprove() {
      return existingData().status == 'open'
        && existingData().requesterId != request.auth.uid
        && incomingData().ownerId == request.auth.uid
        && (incomingData().status == 'approved' || incomingData().status == 'confirmed')
        && 'ownerName' in incomingData()
        && 'spotNumber' in incomingData()
        && 'ownerPhone' in incomingData()
        && incomingData().requesterId == existingData().requesterId;
    }

    // Requester confirms car number (after owner approved)
    function canRequesterConfirm() {
      return existingData().status == 'approved'
        && existingData().requesterId == request.auth.uid
        && incomingData().status == 'confirmed'
        && 'carNumber' in incomingData()
        && incomingData().carNumber.size() >= 7
        && incomingData().ownerId == existingData().ownerId
        && incomingData().spotNumber == existingData().spotNumber;
    }

    // Either party can cancel an active session (end early)
    function canEitherCancel() {
      return (existingData().requesterId == request.auth.uid
           || existingData().ownerId == request.auth.uid)
        && existingData().status in ['approved', 'confirmed']
        && incomingData().status == 'cancelled'
        && incomingData().requesterId == existingData().requesterId
        && incomingData().ownerId == existingData().ownerId;
    }

    // Requester marks confirmed session as completed (left early)
    function canRequesterComplete() {
      return existingData().requesterId == request.auth.uid
        && existingData().status == 'confirmed'
        && incomingData().status == 'completed';
    }

    // Owner reverts their own approval back to open (anytime before requester confirms)
    function canOwnerRevertApproval() {
      return existingData().ownerId == request.auth.uid
        && existingData().status == 'approved'
        && incomingData().status == 'open'
        && incomingData().requesterId == existingData().requesterId;
    }

    // ── users ─────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);

      allow update: if isOwner(uid);

      allow delete: if false;
    }

    // ── parkingRequests ───────────────────────────────────
    match /parkingRequests/{requestId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && incomingData().requesterId == request.auth.uid
        && incomingData().status == 'open'
        && incomingData().fromTime < incomingData().toTime
        && incomingData().toTime > request.time
        && incomingData().toTime < request.time + duration.value(7, 'd')
        && 'requesterName' in incomingData()
        && 'requesterApartment' in incomingData()
        && 'requesterTower' in incomingData();

      allow update: if isAuth() && (
        canRequesterUpdate()
        || canOwnerApprove()
        || canRequesterConfirm()
        || canEitherCancel()
        || canOwnerRevertApproval()
        || canRequesterComplete()
      );

      allow delete: if false;
    }

    // ── spotAvailability ─────────────────────────────────
    match /spotAvailability/{docId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && incomingData().ownerId == request.auth.uid;
      allow update: if isAuth()
        && existingData().ownerId == request.auth.uid;
      allow delete: if false;
    }

    // ── availabilityRules ────────────────────────────────
    match /availabilityRules/{ruleId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && incomingData().ownerId == request.auth.uid;
      allow update: if isAuth()
        && existingData().ownerId == request.auth.uid;
      allow delete: if isAuth()
        && existingData().ownerId == request.auth.uid;
    }

    // ── parkingPings ─────────────────────────────────────
    match /parkingPings/{pingId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && incomingData().fromUid == request.auth.uid;
    }

    // ── thanks ───────────────────────────────────────────
    match /thanks/{thankId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && incomingData().fromUid == request.auth.uid;
    }
  }
}
